# Google OAuth — Create credentials at https://console.cloud.google.com/apis/credentials
# Then set the value below (never commit real credentials)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Google Maps — Enable Places API at https://console.cloud.google.com/apis/library/places-backend.googleapis.com
# Then create an API key at https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
