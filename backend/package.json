{
  "name": "soma-surya-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/index.cjs",
    "start": "node dist/index.cjs",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.86.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "stripe": "^17.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.14.0",
    "@types/supertest": "^6.0.2",
    "esbuild": "^0.25.0",
    "prisma": "^6.5.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "~5.8.2",
    "vitest": "^3.1.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
