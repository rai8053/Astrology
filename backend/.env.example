# Soma & Surya Backend — Environment Configuration
# Copy this file to backend/.env and fill in your values.
# NEVER commit backend/.env to version control.

PORT=4000
NODE_ENV=development
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:4000
LOG_LEVEL=info

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/soma_surya?schema=public"

# Redis
REDIS_URL=redis://localhost:6379

# JWT — Generate using: openssl rand -base64 64
JWT_SECRET="replace-with-strong-random-secret"
JWT_REFRESH_SECRET="replace-with-another-strong-random-secret"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenRouter
OPENROUTER_API_KEY="sk-or-v1-your-key-here"
OPENROUTER_MODEL="deepseek/deepseek-chat-v3-0324"
OPENROUTER_FALLBACK_MODELS="qwen/qwen3-235b-a22b,claude-sonnet-4"
OPENROUTER_MAX_RETRIES=3

# Stripe
STRIPE_SECRET_KEY="sk_test_your_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"
STRIPE_PRO_PRICE_ID="price_xxx"
STRIPE_PREMIUM_PRICE_ID="price_xxx"
STRIPE_ENTERPRISE_PRICE_ID="price_xxx"

# Google OAuth
GOOGLE_CLIENT_ID="your_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your_secret_here"

# iFLYTEK Voice
XF_APPID="your_iflytek_appid"
XF_API_KEY="your_iflytek_api_key"
XF_API_SECRET="your_iflytek_api_secret"

# Email
RESEND_API_KEY="re_your_key_here"
FROM_EMAIL="noreply@somasurya.com"
CONTACT_EMAIL="hello@somaandsurya.com"

# Error tracking
SENTRY_DSN=""
SENTRY_SAMPLE_RATE=0.1
