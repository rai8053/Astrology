# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/soma_surya?schema=public"

# OpenRouter (single AI provider — get a key at https://openrouter.ai)
OPENROUTER_API_KEY="sk-or-v1-..."
# Preferred model (default: deepseek/deepseek-chat-v3-0324)
OPENROUTER_MODEL="deepseek/deepseek-chat-v3-0324"
# Comma-separated fallback models tried in order after preferred model
OPENROUTER_FALLBACK_MODELS="qwen/qwen3-235b-a22b,anthropic/claude-sonnet-4"
# Max retries per model before falling through (default: 3)
# OPENROUTER_MAX_RETRIES=3

# JWT
JWT_SECRET="your-jwt-secret-here-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-here-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Create price IDs in Stripe Dashboard and set them below:
# STRIPE_PRO_PRICE_ID="price_xxx"
# STRIPE_PREMIUM_PRICE_ID="price_xxx"
# STRIPE_ENTERPRISE_PRICE_ID="price_xxx"

# Social Login
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Redis (optional)
REDIS_URL=""

# Analytics
POSTHOG_KEY=""
SENTRY_DSN=""

# App
APP_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:5173,http://localhost:4000
