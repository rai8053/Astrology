# =============================================================================
# Soma & Surya — Environment Configuration
# =============================================================================
# Copy this file to backend/.env and frontend/.env, then fill in your values.
# NEVER commit the actual .env files to version control.
# =============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:4000
LOG_LEVEL=info

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/soma_surya?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Authentication ──────────────────────────────────────────────────────
# Generate using: openssl rand -base64 64
JWT_SECRET="replace-with-a-strong-random-secret-at-least-32-chars"
JWT_REFRESH_SECRET="replace-with-another-strong-random-secret-at-least-32-chars"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AI Provider (OpenRouter or compatible) ───────────────────────────────────
# AI_API_KEY + AI_BASE_URL — any OpenAI-compatible provider.
# hcnsec example: https://api.hcnsec.cn (DeepSeek-V4-Flash, DeepSeek-V4-Pro, etc.)
# OpenRouter example: https://openrouter.ai/api/v1
# See hcnsec models: curl https://api.hcnsec.cn/v1/models -H "Authorization: Bearer \$AI_API_KEY"
AI_API_KEY="sk-your-key-here"
AI_BASE_URL="https://api.hcnsec.cn/v1"
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="DeepSeek-V4-Flash"
OPENROUTER_FALLBACK_MODELS="DeepSeek-V4-Pro,glm-5.2,step-3.7-flash"
OPENROUTER_MAX_RETRIES=3

# ─── Stripe Payments ─────────────────────────────────────────────────────────
# Create products at https://dashboard.stripe.com/products
STRIPE_SECRET_KEY="sk_test_your_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"
STRIPE_PRO_PRICE_ID="price_your_pro_plan_id"
STRIPE_PREMIUM_PRICE_ID="price_your_premium_plan_id"
STRIPE_ENTERPRISE_PRICE_ID="price_your_enterprise_plan_id"

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your_client_id_here.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your_client_secret_here"

# ─── iFLYTEK Voice Services ──────────────────────────────────────────────────
XF_APPID="your_iflytek_app_id"
XF_API_KEY="your_iflytek_api_key"
XF_API_SECRET="your_iflytek_api_secret"

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_your_resend_api_key"
FROM_EMAIL="noreply@somasurya.com"
CONTACT_EMAIL="hello@somaandsurya.com"

# ─── Error Tracking ──────────────────────────────────────────────────────────
SENTRY_DSN=""
SENTRY_SAMPLE_RATE=0.1
